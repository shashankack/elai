# Mercur Store API (same backend as elai-client)
# On a physical device, use your machine's LAN IP — not localhost.
# Example: http://192.168.1.100:9000
EXPO_PUBLIC_MEDUSA_URL=http://localhost:9000

# Publishable API key from Mercur admin → Settings → Publishable API Keys
EXPO_PUBLIC_MEDUSA_PUBLISHABLE_API_KEY=pk_your_key_here
